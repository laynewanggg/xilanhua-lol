/* ============================
   LOL 内战随机器 v2.0 小程序样式
   深色电竞主题
   ============================ */

.app {
  position: relative;
  min-height: 100vh;
  padding: 32rpx 24rpx 60rpx;
  overflow-x: hidden;
  background: #0a0e1a;
}

/* 背景光效 */
.bg-glow {
  position: fixed;
  top: -200rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 800rpx;
  height: 600rpx;
  background: radial-gradient(ellipse, rgba(59, 130, 246, 0.08) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

/* ---- 顶部标题 ---- */
.header {
  margin-bottom: 28rpx;
  position: relative;
  z-index: 1;
}

.logo-area {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.logo-icon {
  font-size: 64rpx;
}

.title-area {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  color: #a78bfa;
}

.subtitle {
  color: #8892a8;
  font-size: 22rpx;
  margin-top: 4rpx;
}

/* ---- 通用卡片 ---- */
.card {
  background: #111827;
  border: 2rpx solid #1e2a42;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #e2e8f0;
  display: block;
  margin-bottom: 20rpx;
}

/* ---- 控制面板 ---- */
.control-panel {
  padding: 28rpx;
}

.control-row {
  margin-bottom: 20rpx;
}

.toggle-group {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.bp-switch {
  transform: scale(0.8);
}

.switch-text {
  font-weight: 600;
  font-size: 26rpx;
  color: #e2e8f0;
}

.hint {
  color: #8892a8;
  font-size: 22rpx;
}

/* 按钮组 */
.btn-group {
  display: flex;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  border-radius: 16rpx;
  padding: 16rpx 0;
  font-size: 26rpx;
  font-weight: 600;
  flex: 1;
  line-height: 1.4;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #3b82f6, #6366f1);
  color: #fff;
  box-shadow: 0 0 30rpx rgba(59, 130, 246, 0.25);
}

.btn-ghost {
  background: transparent;
  color: #8892a8;
  border: 2rpx solid #1e2a42;
}

.btn-sm {
  padding: 10rpx 20rpx;
  font-size: 22rpx;
  flex: none;
  border-radius: 12rpx;
}

/* 状态栏 */
.status-bar {
  padding: 16rpx 20rpx;
  background: #1e293b;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #8892a8;
}

.status-bar.success {
  color: #10b981;
  background: rgba(16, 185, 129, 0.08);
  border: 2rpx solid rgba(16, 185, 129, 0.2);
}

.status-bar.error {
  color: #ef4444;
  background: rgba(239, 68, 68, 0.08);
  border: 2rpx solid rgba(239, 68, 68, 0.2);
}

/* ---- Ban 面板 ---- */
.ban-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.ban-header .card-title {
  margin-bottom: 0;
}

.ban-controls {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.ban-input {
  background: #1e293b;
  border: 2rpx solid #1e2a42;
  border-radius: 10rpx;
  color: #e2e8f0;
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  width: 280rpx;
}

.ban-suggestions {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
  max-height: 200rpx;
  overflow-y: auto;
}

.sug-item {
  display: inline-block;
  padding: 8rpx 18rpx;
  font-size: 22rpx;
  background: #1e293b;
  border: 2rpx solid #1e2a42;
  border-radius: 999rpx;
  color: #8892a8;
}

.ban-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  min-height: 40rpx;
}

.ban-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 18rpx;
  font-size: 22rpx;
  font-weight: 600;
  background: rgba(127, 29, 29, 0.2);
  border: 2rpx solid rgba(239, 68, 68, 0.25);
  border-radius: 999rpx;
  color: #ef4444;
}

/* ---- 英雄池统计 ---- */
.stats-grid {
  display: flex;
  gap: 12rpx;
}

.stat-item {
  flex: 1;
  background: #1e293b;
  border-radius: 16rpx;
  padding: 20rpx 10rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.stat-role {
  font-size: 20rpx;
  color: #8892a8;
  margin-bottom: 6rpx;
}

.stat-count {
  font-size: 34rpx;
  font-weight: 800;
  color: #f59e0b;
}

.stat-avail {
  font-size: 18rpx;
  color: #4a5568;
  margin-top: 4rpx;
}

/* ---- 阵容展示 ---- */
.teams-section {
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.team-card {
  background: #111827;
  border: 2rpx solid #1e2a42;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 0;
}

.team-blue {
  border-color: rgba(59, 130, 246, 0.2);
}

.team-red {
  border-color: rgba(239, 68, 68, 0.2);
}

.team-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 20rpx 24rpx;
}

.team-header.blue {
  background: linear-gradient(135deg, rgba(30, 58, 95, 0.25), transparent);
}

.team-header.red {
  background: linear-gradient(135deg, rgba(95, 30, 30, 0.25), transparent);
}

.team-badge {
  font-size: 32rpx;
}

.team-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #e2e8f0;
}

.lineup {
  padding: 0;
}

.lineup-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 24rpx;
  border-top: 2rpx solid #1e2a42;
}

/* 动画 */
.teams-section.show .blue-item {
  animation: slideInLeft 0.4s ease forwards;
  opacity: 0;
}

.teams-section.show .red-item {
  animation: slideInRight 0.4s ease forwards;
  opacity: 0;
}

@keyframes slideInLeft {
  from {
    opacity: 0;
    transform: translateX(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(30rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.role-info {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.role-icon-box {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1e293b;
  border-radius: 12rpx;
}

.role-icon {
  font-size: 28rpx;
}

.role-name {
  font-size: 22rpx;
  color: #8892a8;
  font-weight: 500;
}

.hero-name {
  font-size: 28rpx;
  font-weight: 700;
}

.blue-hero {
  color: #60a5fa;
}

.red-hero {
  color: #f87171;
}

.empty-lineup {
  padding: 40rpx 0;
  text-align: center;
}

/* VS 分隔 */
.vs-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
}

.vs-text {
  font-size: 44rpx;
  font-weight: 900;
  color: #f59e0b;
}

/* ---- 已上场英雄 ---- */
.used-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.used-header .card-title {
  margin-bottom: 0;
}

.used-badge {
  display: inline-block;
  padding: 6rpx 18rpx;
  background: rgba(59, 130, 246, 0.1);
  border: 2rpx solid rgba(59, 130, 246, 0.2);
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #3b82f6;
}

.used-progress-wrap {
  height: 8rpx;
  background: #1e293b;
  border-radius: 4rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.used-progress {
  height: 100%;
  background: linear-gradient(90deg, #3b82f6, #8b5cf6, #ef4444);
  border-radius: 4rpx;
  transition: width 0.6s ease;
}

.used-pool {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  min-height: 30rpx;
}

.used-chip {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: #1e293b;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #8892a8;
  border: 2rpx solid #1e2a42;
}

/* ---- 彩蛋 ---- */
.easter-egg {
  position: fixed;
  top: 200rpx;
  left: 50%;
  transform: translateX(-50%) translateY(-80rpx);
  z-index: 90;
  opacity: 0;
  transition: all 0.5s ease;
  pointer-events: none;
}

.easter-egg.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

.easter-egg-box {
  padding: 24rpx 40rpx;
  background: rgba(17, 24, 39, 0.95);
  border: 2rpx solid #f59e0b;
  border-radius: 16rpx;
  text-align: center;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.6);
}

.easter-egg-label {
  display: block;
  font-size: 20rpx;
  color: #f59e0b;
  letter-spacing: 4rpx;
  margin-bottom: 10rpx;
}

.easter-egg-quote {
  display: block;
  font-size: 28rpx;
  color: #e2e8f0;
  font-weight: 700;
}

/* ---- 历史记录弹窗 ---- */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-overlay.open {
  display: flex;
}

.modal {
  background: #111827;
  border: 2rpx solid #1e2a42;
  border-radius: 24rpx;
  width: 88%;
  max-height: 80vh;
  overflow: hidden;
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.6);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 2rpx solid #1e2a42;
}

.modal-header .card-title {
  margin-bottom: 0;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8892a8;
  font-size: 36rpx;
  border-radius: 10rpx;
}

.modal-body {
  padding: 24rpx;
  max-height: 60vh;
}

.history-round {
  background: #1e293b;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.history-round:last-child {
  margin-bottom: 0;
}

.round-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #f59e0b;
  margin-bottom: 16rpx;
}

.round-teams {
  display: flex;
  gap: 16rpx;
}

.round-team {
  flex: 1;
}

.round-team-title {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.blue-round .round-team-title {
  color: #60a5fa;
}

.red-round .round-team-title {
  color: #f87171;
}

.round-hero {
  display: flex;
  justify-content: space-between;
  padding: 6rpx 0;
}

.round-role {
  font-size: 20rpx;
  color: #8892a8;
}

.round-name {
  font-size: 22rpx;
  color: #e2e8f0;
  font-weight: 600;
}

/* ---- 底部 ---- */
.footer {
  text-align: center;
  padding: 24rpx;
  color: #4a5568;
  font-size: 20rpx;
  margin-top: 20rpx;
}

/* ---- 通用 ---- */
.empty-text {
  color: #4a5568;
  font-size: 22rpx;
}

.empty-text.center {
  display: block;
  text-align: center;
  padding: 40rpx 0;
}
