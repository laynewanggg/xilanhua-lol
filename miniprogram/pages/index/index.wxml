<view class="app">
  <!-- 背景光效 -->
  <view class="bg-glow"></view>

  <!-- 顶部标题 -->
  <view class="header" bindlongpress="onLongPressHeader">
    <view class="logo-area">
      <text class="logo-icon">⚔️</text>
      <view class="title-area">
        <text class="title">LOL 内战随机器</text>
        <text class="subtitle">v2.0 · 10人阵容生成 · {{totalHeroes}}位英雄全覆盖</text>
      </view>
    </view>
  </view>

  <!-- 彩蛋弹窗 -->
  <view class="easter-egg {{showEasterEgg ? 'show' : ''}}">
    <view class="easter-egg-box">
      <text class="easter-egg-label">📡 战场通讯</text>
      <text class="easter-egg-quote">{{easterEggQuote}}</text>
    </view>
  </view>

  <!-- 控制面板 -->
  <view class="card control-panel">
    <view class="control-row">
      <view class="toggle-group">
        <switch checked="{{globalBp}}" bindchange="onGlobalBpChange" color="#3b82f6" class="bp-switch" />
        <text class="switch-text">全局 BP 模式</text>
        <text class="hint">（已上场不可重复）</text>
      </view>
    </view>
    <view class="btn-group">
      <button class="btn btn-primary" bindtap="generateLineup">🎲 生成阵容</button>
      <button class="btn btn-ghost" bindtap="resetGame">🔄 重置</button>
      <button class="btn btn-ghost" bindtap="openHistory">📋 历史</button>
    </view>
    <view class="status-bar {{statusType}}" wx:if="{{status}}">
      <text>{{status}}</text>
    </view>
  </view>

  <!-- Ban 英雄面板 -->
  <view class="card ban-panel">
    <view class="ban-header">
      <text class="card-title">🚫 Ban 英雄</text>
      <view class="ban-controls">
        <input
          class="ban-input"
          placeholder="输入英雄名搜索..."
          placeholder-style="color:#4a5568"
          value="{{banInput}}"
          bindinput="onBanInput"
          bindconfirm="onBanConfirm"
        />
        <view class="btn btn-sm btn-ghost" bindtap="clearAllBans">清空</view>
      </view>
    </view>

    <!-- 搜索建议 -->
    <view class="ban-suggestions" wx:if="{{banSuggestions.length > 0}}">
      <view
        class="sug-item"
        wx:for="{{banSuggestions}}"
        wx:key="*this"
        data-hero="{{item}}"
        bindtap="onSelectBanHero"
      >{{item}}</view>
    </view>

    <!-- Ban 列表 -->
    <view class="ban-list">
      <view
        class="ban-chip"
        wx:for="{{bannedList}}"
        wx:key="*this"
        data-hero="{{item}}"
        bindtap="onRemoveBan"
      >✕ {{item}}</view>
      <text class="empty-text" wx:if="{{bannedList.length === 0}}">暂无 Ban 位</text>
    </view>
  </view>

  <!-- 英雄池统计 -->
  <view class="card stats-panel">
    <text class="card-title">📊 英雄池统计</text>
    <view class="stats-grid">
      <view class="stat-item" wx:for="{{roleStats}}" wx:key="role">
        <text class="stat-icon">{{item.icon}}</text>
        <text class="stat-role">{{item.role}}</text>
        <text class="stat-count">{{item.total}}</text>
        <text class="stat-avail">可用 {{item.available}}</text>
      </view>
    </view>
  </view>

  <!-- 阵容展示 -->
  <view class="teams-section {{showTeams ? 'show' : ''}}">
    <!-- 蓝色方 -->
    <view class="team-card team-blue">
      <view class="team-header blue">
        <text class="team-badge">🔵</text>
        <text class="team-title">蓝色方</text>
      </view>
      <view class="lineup">
        <view class="lineup-item blue-item" wx:for="{{blueTeam}}" wx:key="role"
          style="animation-delay: {{index * 0.1}}s">
          <view class="role-info">
            <view class="role-icon-box">
              <text class="role-icon">{{item.icon}}</text>
            </view>
            <text class="role-name">{{item.role}}</text>
          </view>
          <text class="hero-name blue-hero">{{item.hero}}</text>
        </view>
        <view class="empty-lineup" wx:if="{{blueTeam.length === 0}}">
          <text class="empty-text">等待生成...</text>
        </view>
      </view>
    </view>

    <!-- VS 分隔 -->
    <view class="vs-divider">
      <text class="vs-text">VS</text>
    </view>

    <!-- 红色方 -->
    <view class="team-card team-red">
      <view class="team-header red">
        <text class="team-badge">🔴</text>
        <text class="team-title">红色方</text>
      </view>
      <view class="lineup">
        <view class="lineup-item red-item" wx:for="{{redTeam}}" wx:key="role"
          style="animation-delay: {{index * 0.1 + 0.05}}s">
          <view class="role-info">
            <view class="role-icon-box">
              <text class="role-icon">{{item.icon}}</text>
            </view>
            <text class="role-name">{{item.role}}</text>
          </view>
          <text class="hero-name red-hero">{{item.hero}}</text>
        </view>
        <view class="empty-lineup" wx:if="{{redTeam.length === 0}}">
          <text class="empty-text">等待生成...</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 已上场英雄 -->
  <view class="card used-section">
    <view class="used-header">
      <text class="card-title">🏟️ 已上场英雄</text>
      <text class="used-badge">{{usedCount}} / {{totalHeroes}}</text>
    </view>
    <view class="used-progress-wrap">
      <view class="used-progress" style="width: {{usedProgress}}%"></view>
    </view>
    <view class="used-pool">
      <view class="used-chip" wx:for="{{usedPool}}" wx:key="*this">{{item}}</view>
      <text class="empty-text" wx:if="{{usedPool.length === 0}}">暂无英雄上场</text>
    </view>
  </view>

  <!-- 历史记录弹窗 -->
  <view class="modal-overlay {{showHistory ? 'open' : ''}}" bindtap="onHistoryMaskTap">
    <view class="modal" catchtap="preventBubble">
      <view class="modal-header">
        <text class="card-title">📋 历史记录</text>
        <view class="modal-close" bindtap="closeHistory">
          <text>✕</text>
        </view>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <view class="history-round" wx:for="{{historyRounds}}" wx:key="round">
          <text class="round-title">第 {{item.round}} 轮 · {{item.time}}</text>
          <view class="round-teams">
            <view class="round-team blue-round">
              <text class="round-team-title">🔵 蓝色方</text>
              <view class="round-hero" wx:for="{{item.blue}}" wx:key="role" wx:for-item="h">
                <text class="round-role">{{h.icon}} {{h.role}}</text>
                <text class="round-name">{{h.hero}}</text>
              </view>
            </view>
            <view class="round-team red-round">
              <text class="round-team-title">🔴 红色方</text>
              <view class="round-hero" wx:for="{{item.red}}" wx:key="role" wx:for-item="h">
                <text class="round-role">{{h.icon}} {{h.role}}</text>
                <text class="round-name">{{h.hero}}</text>
              </view>
            </view>
          </view>
        </view>
        <text class="empty-text center" wx:if="{{historyRounds.length === 0}}">暂无历史记录</text>
      </scroll-view>
    </view>
  </view>

  <!-- 底部 -->
  <view class="footer">
    <text>西兰花 LOL 内战随机器 v2.0 · 172位英雄全覆盖</text>
  </view>
</view>
